{
  "name": "drop2",
  "version": "1.0.0",
  "description": "Personal drop/notes dashboard",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "docker compose up -d mongo && concurrently \"nodemon server.js\" \"npm run dev --prefix client\"",
    "build": "npm run build --prefix client",
    "mongo:stop": "docker compose stop mongo"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "multer": "^1.4.5-lts.1",
    "socket.io": "^4.6.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2"
  }
}
